{
  "scanSettings": {
    "configMode": "LOCAL",
    "configExternalURL": "",
    "projectToken": "",
    "baseBranches": [],
    "versioning": {    
      "java": "21",  
      "gradle": ">=9.0.0"   
    }
  },
  "checkRunSettings": {
    "vulnerableCheckRunConclusionLevel": "failure",
    "displayMode": "diff",
    "useMendCheckNames": true
